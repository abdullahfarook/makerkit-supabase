# =============================================================================
# Makerkit / Hotel Admin – Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# For local Supabase dev, also ensure .env.development has SUPABASE_* and
# SUPABASE_SERVICE_ROLE_KEY. For production, use .env.production for Supabase.
# =============================================================================

# -----------------------------------------------------------------------------
# Site (required)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_PRODUCT_NAME=Makerkit
NEXT_PUBLIC_SITE_TITLE="Makerkit - The easiest way to build and manage your SaaS"
NEXT_PUBLIC_SITE_DESCRIPTION="Makerkit is the easiest way to build and manage your SaaS."
NEXT_PUBLIC_DEFAULT_LOCALE=en
NEXT_PUBLIC_DEFAULT_THEME_MODE=light
NEXT_PUBLIC_THEME_COLOR="#ffffff"
NEXT_PUBLIC_THEME_COLOR_DARK="#0a0a0a"

# -----------------------------------------------------------------------------
# Supabase (required for auth/database)
# -----------------------------------------------------------------------------
# Set in .env.development for local (Supabase CLI) or .env.production for prod.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# -----------------------------------------------------------------------------
# Auth
# -----------------------------------------------------------------------------
NEXT_PUBLIC_AUTH_PASSWORD=true
NEXT_PUBLIC_AUTH_MAGIC_LINK=false
NEXT_PUBLIC_DISPLAY_TERMS_AND_CONDITIONS_CHECKBOX=false
# reCAPTCHA: optional; set both if you use captcha on sign-in/sign-up
NEXT_PUBLIC_CAPTCHA_SITE_KEY=
CAPTCHA_SECRET_TOKEN=

# -----------------------------------------------------------------------------
# Feature flags (required by app config)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_ENABLE_THEME_TOGGLE=true
NEXT_PUBLIC_LANGUAGE_PRIORITY=application
NEXT_PUBLIC_ENABLE_VERSION_UPDATER=false
NEXT_PUBLIC_ENABLE_PERSONAL_ACCOUNT_DELETION=true

# -----------------------------------------------------------------------------
# Navigation & sidebar
# -----------------------------------------------------------------------------
NEXT_PUBLIC_NAVIGATION_STYLE=sidebar
NEXT_PUBLIC_HOME_SIDEBAR_COLLAPSED=true
NEXT_PUBLIC_SIDEBAR_COLLAPSIBLE_STYLE=
NEXT_PUBLIC_ENABLE_SIDEBAR_TRIGGER=
NEXT_PUBLIC_EXPAND_SIDEBAR_ON_HOVER=

# -----------------------------------------------------------------------------
# Version updater (optional)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_VERSION_UPDATER_REFETCH_INTERVAL_SECONDS=

# -----------------------------------------------------------------------------
# i18n / Locales
# -----------------------------------------------------------------------------
NEXT_PUBLIC_LOCALES_PATH=apps/web/public/locales

# -----------------------------------------------------------------------------
# Password rules (optional; defaults false)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_PASSWORD_REQUIRE_SPECIAL_CHARS=
NEXT_PUBLIC_PASSWORD_REQUIRE_NUMBERS=
NEXT_PUBLIC_PASSWORD_REQUIRE_UPPERCASE=

# -----------------------------------------------------------------------------
# Build / runtime (optional)
# -----------------------------------------------------------------------------
LOGGER=pino
ENABLE_REACT_COMPILER=false
# Set to true in CI/test (e.g. .env.test) to allow http NEXT_PUBLIC_SITE_URL
NEXT_PUBLIC_CI=
